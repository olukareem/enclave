# Enclave — environment variables
#
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real credentials.

# ── Neon Postgres ──────────────────────────────────────────────────────────
# Connection string from your Neon project:
#   neon.tech → your project → Connection Details → Connection string
#
# Neon free tier: 0.5 GB storage, 10 branches, serverless compute.
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/enclave?sslmode=require

# ── Auth.js ────────────────────────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
# Or:                      npx auth secret
AUTH_SECRET=your-32-char-random-secret

# Base URL of the app. Used by Auth.js for CSRF and redirect validation.
#   Development:  http://localhost:3000
#   Production:   https://your-vercel-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# ── Vercel Blob ────────────────────────────────────────────────────────────
# Token from your Vercel Blob store:
#   vercel.com → Storage → Create Blob Store → name it "enclave-docs" → copy token
#
# Vercel Blob free tier: 500 MB storage, 1 GB/month bandwidth.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Optional: the public base URL of your blob store (used by /api/blob for URL construction).
# Leave blank — Vercel sets this automatically in production.
BLOB_STORE_URL=
